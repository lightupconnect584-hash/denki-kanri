generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String?
  inviteToken String?   @unique
  role        String    @default("PARTNER")
  companyName String?
  avatarUrl        String?
  phone            String?
  color            String?
  thankYouEnabled  Boolean @default(true)
  thankYouImageUrl String?
  thankYouMessage  String?
  // 基本情報（協力会社向け）
  address          String?
  birthDate        DateTime?
  bloodType        String?
  emergencyName    String?
  emergencyPhone   String?
  licenseType      String?
  licenseNumber    String?
  licenseExpiry    DateTime?
  vehicleNumber    String?
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?

  assignedProjects Project[]   @relation("AssignedTo")
  createdProjects  Project[]   @relation("CreatedBy")
  inspections      Inspection[]
  quotes           Quote[]
  comments         Comment[]
  reactions        Reaction[]
  activityLogs     ActivityLog[]
  modelsCreated    ReplacementModel[] @relation("ModelCreatedBy")
  modelsUpdated    ReplacementModel[] @relation("ModelUpdatedBy")
  loginLogs         LoginLog[]
  pushSubscriptions PushSubscription[]
  sentDMs          DirectMessage[] @relation("SentDMs")
  receivedDMs      DirectMessage[] @relation("ReceivedDMs")
  invoices         Invoice[]
  monthlyInvoices  MonthlyInvoice[] @relation("PartnerMonthlyInvoices")
}

model LoginLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id               String    @id @default(cuid())
  title            String
  location         String
  contractorName   String?
  contractorPhone  String?
  smsAllowed       Boolean   @default(false)
  description      String?
  workType         String?
  roomNumber       String?
  preferredContactAt String?
  preferredVisitAt   String?
  moveInDate         String?
  receivedAt         String?
  parkingInfo        String?
  urgency          String    @default("LOW")
  materialSupplied Boolean   @default(false)
  simpleReport     Boolean   @default(false)
  onHold           Boolean   @default(false)
  holdReason       String?
  holdAt           DateTime?
  holdByName       String?
  amount           Int?
  salesAmount      Int?      // 売上（積水への請求額・税別）。協力会社には非公開
  materialCost     Int?      // 材料費（税別）。協力会社には非公開
  managerName      String?   // 管理担当者名（依頼元）。協力会社には非公開
  afterManagerName String?   // アフター担当者名（依頼元）。協力会社には非公開
  billingMonth     String?   // 請求月の上書き（YYYY-MM）。未設定なら作業月を使用
  visitDate        DateTime?
  visitTime        String?
  status           String    @default("PENDING")
  dueDate          DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  notifyAdminAt    DateTime?
  notifyPartnerAt  DateTime?

  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedToId String?

  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])
  createdById String

  inspections   Inspection[]
  quotes        Quote[]
  projectPhotos ProjectPhoto[]
  invoices      Invoice[]
  comments      Comment[]
  activityLogs  ActivityLog[]
}

model ProjectPhoto {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  createdAt    DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id])
  projectId String
}

model Invoice {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  createdAt    DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  uploadedBy   User   @relation(fields: [uploadedById], references: [id])
  uploadedById String
}

// 依頼書の受付ボックス（ペーパーレス受付→振り分け）
model IntakeDoc {
  id            String   @id @default(cuid())
  filename      String   // BlobのURL
  originalName  String
  createdByName String?
  status        String   @default("PENDING") // PENDING / PROCESSED
  projectId     String?  // 振り分け先の案件
  createdAt     DateTime @default(now())
}

// 月次売上の明細行（アプリ内売上集計）
model SalesEntry {
  id        String   @id @default(cuid())
  yearMonth String   // 例: "2026-06"
  category  String   @default("SEKISUI_KITA") // SEKISUI_KITA / SEKISUI_SAITAMA / PERSONAL / OTHER
  label     String   @default("") // 建物名・内容
  sales     Int      @default(0)  // 売上
  material  Int      @default(0)  // 材料費
  outsource Int      @default(0)  // 外注工費
  projectId String?  @unique      // 完了案件から取り込んだ場合の元案件
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// 毎月の経費マスタ（全月共通で計上）
model ExpenseItem {
  id        String   @id @default(cuid())
  label     String
  amount    Int      @default(0)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// 月締め一括請求（協力会社が毎月1枚アップロード）
model MonthlyInvoice {
  id           String   @id @default(cuid())
  yearMonth    String   // 例: "2026-06"
  filename     String
  originalName String
  createdAt    DateTime @default(now())

  partner   User   @relation("PartnerMonthlyInvoices", fields: [partnerId], references: [id])
  partnerId String
}

model Inspection {
  id        String   @id @default(cuid())
  result    String
  workDate  DateTime
  workDates String[] @default([])
  notes     String?
  polishedReport String? // AI清書（積水ハウス向け報告文）
  createdAt DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  inspector   User   @relation(fields: [inspectorId], references: [id])
  inspectorId String

  photos Photo[]
}

model Photo {
  id           String     @id @default(cuid())
  filename     String
  originalName String
  category     String     @default("before")
  createdAt    DateTime   @default(now())

  inspection   Inspection @relation(fields: [inspectionId], references: [id])
  inspectionId String
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  detail    String?
  createdAt DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  user      User?   @relation(fields: [userId], references: [id])
  userId    String?
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  createdAt DateTime  @default(now())
  readAt    DateTime?

  project   Project    @relation(fields: [projectId], references: [id])
  projectId String

  author    User       @relation(fields: [authorId], references: [id])
  authorId  String

  reactions Reaction[]
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String
  createdAt DateTime @default(now())

  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId String

  user      User   @relation(fields: [userId], references: [id])
  userId    String

  @@unique([commentId, userId, emoji])
}

model ReplacementCategory {
  id        String             @id @default(cuid())
  name      String
  order     Int                @default(0)
  createdAt DateTime           @default(now())
  models    ReplacementModel[]
}

model ReplacementModel {
  id               String   @id @default(cuid())
  existingModel    String
  replacementModel String
  maker            String?
  color            String?
  price            Int?
  replacementCost  Int?
  relatedParts     String[] @default([])
  notes            String?
  updatedOn        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category   ReplacementCategory? @relation(fields: [categoryId], references: [id])
  categoryId String?

  createdBy   User?   @relation("ModelCreatedBy", fields: [createdById], references: [id])
  createdById String?

  updatedBy   User?   @relation("ModelUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model SeasonalMessage {
  id             String   @id @default(cuid())
  name           String
  startMD        Int
  endMD          Int
  message        String
  imageUrl       String?
  animation      String   @default("none")
  enabled        Boolean  @default(true)
  order          Int      @default(0)
  targetType     String   @default("all")
  targetUserIds  String[] @default([])
  createdAt      DateTime @default(now())
}

model SeasonalImageStock {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  label        String?
  createdAt    DateTime @default(now())
}

model WorkTypeMaster {
  id             String   @id @default(cuid())
  name           String
  defaultAmount  Int?
  defaultSales   Int?     // 標準売上額（積水請求・税別）
  defaultUrgency String?
  defaultSimpleReport Boolean @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
}

model DirectMessage {
  id        String    @id @default(cuid())
  content   String
  createdAt DateTime  @default(now())
  readAt    DateTime?

  from      User   @relation("SentDMs", fields: [fromId], references: [id], onDelete: Cascade)
  fromId    String
  to        User   @relation("ReceivedDMs", fields: [toId], references: [id], onDelete: Cascade)
  toId      String
}

model Quote {
  id        String   @id @default(cuid())
  amount    Int?
  notes     String?
  filename  String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  submittedBy   User   @relation(fields: [submittedById], references: [id])
  submittedById String
}
