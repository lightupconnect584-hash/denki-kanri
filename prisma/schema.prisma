generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String
  role        String    @default("PARTNER")
  companyName String?
  avatarUrl        String?
  phone            String?
  color            String?
  thankYouEnabled  Boolean @default(true)
  thankYouImageUrl String?
  thankYouMessage  String?
  createdAt   DateTime  @default(now())

  assignedProjects Project[]   @relation("AssignedTo")
  createdProjects  Project[]   @relation("CreatedBy")
  inspections      Inspection[]
  quotes           Quote[]
  comments         Comment[]
  reactions        Reaction[]
  activityLogs     ActivityLog[]
}

model Project {
  id               String    @id @default(cuid())
  title            String
  location         String
  contractorName   String?
  contractorPhone  String?
  smsAllowed       Boolean   @default(false)
  description      String?
  workType         String?
  roomNumber       String?
  preferredContactAt String?
  preferredVisitAt   String?
  urgency          String    @default("LOW")
  amount           Int?
  visitDate        DateTime?
  visitTime        String?
  status           String    @default("PENDING")
  dueDate          DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  notifyAdminAt    DateTime?
  notifyPartnerAt  DateTime?

  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedToId String?

  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])
  createdById String

  inspections   Inspection[]
  quotes        Quote[]
  projectPhotos ProjectPhoto[]
  comments      Comment[]
  activityLogs  ActivityLog[]
}

model ProjectPhoto {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  createdAt    DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id])
  projectId String
}

model Inspection {
  id        String   @id @default(cuid())
  result    String
  workDate  DateTime
  workDates String[] @default([])
  notes     String?
  createdAt DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  inspector   User   @relation(fields: [inspectorId], references: [id])
  inspectorId String

  photos Photo[]
}

model Photo {
  id           String     @id @default(cuid())
  filename     String
  originalName String
  category     String     @default("before")
  createdAt    DateTime   @default(now())

  inspection   Inspection @relation(fields: [inspectionId], references: [id])
  inspectionId String
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  detail    String?
  createdAt DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  user      User?   @relation(fields: [userId], references: [id])
  userId    String?
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  createdAt DateTime  @default(now())
  readAt    DateTime?

  project   Project    @relation(fields: [projectId], references: [id])
  projectId String

  author    User       @relation(fields: [authorId], references: [id])
  authorId  String

  reactions Reaction[]
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String
  createdAt DateTime @default(now())

  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId String

  user      User   @relation(fields: [userId], references: [id])
  userId    String

  @@unique([commentId, userId, emoji])
}

model SeasonalMessage {
  id             String   @id @default(cuid())
  name           String
  startMD        Int
  endMD          Int
  message        String
  imageUrl       String?
  animation      String   @default("none")
  enabled        Boolean  @default(true)
  order          Int      @default(0)
  targetType     String   @default("all")
  targetUserIds  String[] @default([])
  createdAt      DateTime @default(now())
}

model SeasonalImageStock {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  label        String?
  createdAt    DateTime @default(now())
}

model WorkTypeMaster {
  id             String   @id @default(cuid())
  name           String
  defaultAmount  Int?
  defaultUrgency String?
  order          Int      @default(0)
  createdAt      DateTime @default(now())
}

model Quote {
  id        String   @id @default(cuid())
  amount    Int?
  notes     String?
  filename  String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  submittedBy   User   @relation(fields: [submittedById], references: [id])
  submittedById String
}
